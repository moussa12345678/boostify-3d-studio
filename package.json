    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite-plugin-sri": "^0.0.2"
  }
}
